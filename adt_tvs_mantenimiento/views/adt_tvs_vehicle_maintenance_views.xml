<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_adt_tvs_vehicle_maintenance_tree" model="ir.ui.view">
        <field name="name">adt.tvs.vehicle_maintenance_record.tree</field>
        <field name="model">adt.tvs.vehicle_maintenance_record</field>
        <field name="arch" type="xml">
            <tree string="Mantenimientos por KM">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="estado_mantenimiento"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_adt_tvs_vehicle_maintenance_form" model="ir.ui.view">
        <field name="name">adt.tvs.vehicle_maintenance_record.form</field>
        <field name="model">adt.tvs.vehicle_maintenance_record</field>
        <field name="arch" type="xml">
            <form string="Mantenimiento por KM">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="conductor_id"/>
                        </group>
                        <group>
                            <field name="chassis"/>
                            <field name="motor"/>
                            <field name="placa"/>
                        </group>
                    </group>

                    <group>
                        <field name="estado_mantenimiento"/>
                        <field name="motivo_terceros" attrs="{'invisible':[('estado_mantenimiento','!=','terceros')], 'required': [('estado_mantenimiento','==','terceros')]}"/>
                    </group>

                    <group string="Plan por Kilometraje">
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="km_objetivo"/>
                                <field name="realizado"/>
                                <field name="attachment_ids" widget="many2many_binary" />
                                <field name="fecha_inicio"/>
                                <field name="fecha_fin"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_adt_tvs_vehicle_maintenance" model="ir.actions.act_window">
        <field name="name">Mantenimientos por KM</field>
        <field name="res_model">adt.tvs.vehicle_maintenance_record</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Form view to edit a single maintenance line (used in modal) -->
    <record id="view_adt_tvs_vehicle_maintenance_line_form" model="ir.ui.view">
        <field name="name">adt.tvs.vehicle_maintenance_line.form</field>
        <field name="model">adt.tvs.vehicle_maintenance_line</field>
        <field name="arch" type="xml">
            <form string="Línea de Mantenimiento">
                <sheet>
                    <group>
                        <field name="km_objetivo" readonly="1"/>
                        <field name="realizado"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                        <field name="fecha_inicio"/>
                        <field name="fecha_fin"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
