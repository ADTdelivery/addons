<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_adt_captura_prioridad_urgente" model="ir.actions.act_window">
        <field name="name">Capturas Urgentes</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">adt.captura.mora</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('captura_prioridad','=','urgente')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay capturas urgentes
            </p>
            <p>
                Esta vista muestra automáticamente las cuentas marcadas como prioridad urgente.
            </p>
        </field>
    </record>
</odoo>
