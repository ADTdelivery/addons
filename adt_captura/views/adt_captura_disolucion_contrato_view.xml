<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_adt_captura_disolucion_contrato" model="ir.actions.act_window">
        <field name="name">Disolución de Contrato</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">adt.captura.record</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[("state", "=", "disolucion_contrato")]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay procesos de Disolución de Contrato.
            </p>
        </field>

    </record>

    <record id="view_adt_captura_disolucion_contrato_tree" model="ir.ui.view">
        <field name="name">adt.captura.record.disolucion.contrato.tree</field>
        <field name="model">adt.captura.record</field>
        <field name="arch" type="xml">
            <tree string="Capturas">
                <field name="name"/>
                <field name="source_type"/>
                <field name="cuenta_id"/>
                <field name="vehicle_id"/>
                <field name="dias_mora"/>
                <field name="numero_cuotas_vencidas"/>
                <field name="retention_reason"/>
                <field name="retention_date"/>
                <field name="payment_state" widget="badge"
                       decoration-danger="payment_state == 'pendiente'"
                       decoration-success="payment_state == 'pagado'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'liberado'"
                       decoration-danger="state == 'disolucion_contrato'"
                       decoration-warning="state == 'capturado'"
                       decoration-muted="state == 'cancelado'"/>
                <field name="capturador_id"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>



    <!-- Form View -->
    <record id="view_adt_captura_record_form" model="ir.ui.view">
        <field name="name">adt.captura.record.form</field>
        <field name="model">adt.captura.record</field>
        <field name="arch" type="xml">
            <form string="Registro de Captura">
                <header>

                    <button name="action_liberar"
                            string="Liberar Vehículo"
                            type="object"
                            class="oe_highlight"
                            attrs="{'invisible': [('state', 'not in', ['disolucion_contrato', 'capturado'])]}"
                            groups="adt_captura.group_captura_supervisor"
                            confirm="¿Está seguro de liberar este vehículo?"/>

                    <button name="action_retener"
                            string="Disolución Contrato"
                            type="object"
                            class="btn-danger"
                            attrs="{'invisible': [('state', '!=', 'capturado')]}"
                            groups="adt_captura.group_captura_supervisor"/>

                    <button name="action_recolocar"
                            string="Recolocar Vehículo"
                            type="object"
                            class="btn-danger"
                            attrs="{'invisible': [('state', '!=', 'disolucion_contrato')]}"
                            groups="adt_captura.group_captura_supervisor"
                            confirm="¿Está seguro de recolocar este vehículo?"/>

                    <button name="action_cancelar"
                            string="Cancelar"
                            type="object"
                            attrs="{'invisible': [('es_estado_final', '=', True)]}"
                            groups="adt_captura.group_captura_supervisor"
                            confirm="¿Está seguro de cancelar esta captura?"/>


                    <field name="state" widget="statusbar"
                           statusbar_visible="capturado,liberado,disolucion_contrato,recolocada,cancelado"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_evidencia"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-image-o">
                        </button>

                        <button name="action_ver_cuenta"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-book">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Ver Cuenta</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <field name="source_type" readonly="1"/>
                        <field name="papeleta_id" readonly="1" attrs="{'invisible': [('source_type','=', 'mora')] }"/>
                        <field name="papeleta_monto"
                               widget="monetary"
                               options="{'currency_field': 'currency_id'}"
                               readonly="1" attrs="{'invisible': [('source_type','=', 'mora')] }"/>
                    </group>

                    <group>
                        <group string="Información Principal">
                            <field name="partner_id"/>
                            <field name="cuenta_id"/>
                            <field name="vehicle_id"/>
                            <field name="capturador_id" readonly="1"/>
                        </group>

                        <group string="Información de Mora">
                            <field name="dias_mora"/>
                            <field name="numero_cuotas_vencidas"/>
                            <field name="tipo_cartera"/>
                        </group>
                    </group>

                    <group>
                        <group string="Tipo de Captura">
                            <field name="capture_type"/>
                            <field name="commitment_date"
                                   attrs="{'invisible': [('capture_type', '!=', 'compromiso')],
                                           'required': [('capture_type', '=', 'compromiso')]}"/>
                            <field name="commitment_delay_days" attrs="{'invisible': [('commitment_delay_days', '=', 0)]}"/>
                        </group>

                        <group string="Deuda de Intervención">
                            <field name="intervention_fee"/>
                            <field name="payment_state" widget="badge"
                                   decoration-danger="payment_state == 'pendiente'"
                                   decoration-success="payment_state == 'pagado'"/>
                            <field name="motivo_no_pago"
                                   attrs="{'invisible': [('pagar_monto', '=', 'True')]}"/>

                            <button name="action_registrar_pago"
                                    string="Registrar Pago"
                                    type="object"
                                    class="oe_highlight"
                                    attrs="{'invisible': [('payment_state', '=', 'pagado')]}"/>

                        </group>
                    </group>

                    <group>
                        <group string="Recogida de Vehículo">
                            <field name="moto_recogida"/>
                            <field name="motivo_no_recogida" attrs="{'invisible': [('moto_recogida', '=', True)]}"/>
                        </group>

                        <group string="Liberación de Vehículo" attrs="{'invisible': [('state', '!=', 'liberado')]}" >
                            <field name="liberacion_tipo" readonly="1"/>
                            <field name="observaciones" readonly="1"/>
                        </group>
                    </group>

                    <group string="Disolución de Contrato"  attrs="{'invisible': [('state', 'not in', ['disolucion_contrato', 'recolocada'])]}">
                        <field name="retention_reason" readonly="1"/>
                        <field name="notes" readonly="1"/>
                        <field name="retention_date" readonly="1"/>

                    </group>

                    <group  attrs="{'invisible': [('state', 'not in', ['disolucion_contrato', 'recolocada'])]}">
                        <group string="Apelaciones">
                            <field name="appeal_ids">
                                <tree string="Apelaciones">
                                    <field name="appeal_reason"/>
                                    <field name="appeal_evidence"/>
                                </tree>
                                <form string="Apelación">
                                    <group>
                                        <field name="appeal_reason"/>
                                        <field name="appeal_evidence"/>
                                    </group>
                                </form>
                            </field>

                        </group>
                    </group>

                    <group string="Recolocación"  attrs="{'invisible': [('state', 'not in', ['disolucion_contrato', 'recolocada'])]}">
                        <field name="documento_desafiliacion"/>
                        <field name="evidencia_entrega"/>
                    </group>


                    <notebook>
                        <page string="Evidencia" name="evidencia">
                            <field name="evidencia_archivos" widget="many2many_binary" nolabel="1" string="Evidencias (Fotos/Videos)"/>
                        </page>
                        <page string="Cuotas Pendientes" name="cuotas_pendientes">
                            <field name="cuotas_pendientes_ids" widget="one2many_list" readonly="1">
                                <tree string="Cuotas Pendientes">
                                    <field name="name" string="# Cuota"/>
                                    <field name="monto"/>
                                    <field name="fecha_cronograma"/>
                                    <field name="real_date" string="Fecha de Pago"/>
                                    <field name="state"/>
                                    <field name="saldo"/>
                                    <field name="mora_total"/>
                                    <field name="mora_dias"/>
                                    <field name="mora_estado_texto"/>
                                    <field name="mora_operacion"/>
                                    <field name="periodicidad"/>
                                    <field name="x_asesora"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                    <!-- Hidden fields -->
                    <field name="puede_liberar" invisible="1"/>
                    <field name="es_estado_final" invisible="1"/>
                    <field name="tiene_deuda_anterior" invisible="1"/>
                    <field name="pagar_monto" invisible="1"/>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_adt_captura_record_search" model="ir.ui.view">
        <field name="name">adt.captura.record.search</field>
        <field name="model">adt.captura.record</field>
        <field name="arch" type="xml">
            <search string="Buscar Capturas">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="cuenta_id"/>
                <field name="vehicle_id"/>
                <field name="capturador_id"/>

                <filter string="Origen: Mora" name="filter_origen_mora" domain="[('source_type','=','mora')]"/>
                <filter string="Origen: Papeleta" name="filter_origen_papeleta" domain="[('source_type','=','papeleta')]"/>
                <filter string="Origen: Ambos" name="filter_origen_ambos" domain="[('source_type','=','ambos')]"/>


                <filter string="Capturados" name="filter_capturado"
                        domain="[('state', '=', 'capturado')]"/>
                <filter string="Liberados" name="filter_liberado"
                        domain="[('state', '=', 'liberado')]"/>
                <filter string="Disolución Contrato" name="filter_disolucion_contrato"
                        domain="[('state', '=', 'disolucion_contrato')]"/>
                <separator/>
                <filter string="Pago Pendiente" name="filter_pago_pendiente"
                        domain="[('payment_state', '=', 'pendiente')]"/>
                <filter string="Pago Realizado" name="filter_pago_pagado"
                        domain="[('payment_state', '=', 'pagado')]"/>
                <separator/>
                <filter string="Mis Capturas" name="filter_mis_capturas"
                        domain="[('capturador_id', '=', uid)]"/>
                <separator/>
                <filter string="Fecha de Captura" name="filter_fecha" date="create_date"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Estado Pago" name="group_payment_state"
                            context="{'group_by': 'payment_state'}"/>
                    <filter string="Tipo Captura" name="group_capture_type"
                            context="{'group_by': 'capture_type'}"/>
                    <filter string="Capturador" name="group_capturador"
                            context="{'group_by': 'capturador_id'}"/>
                    <filter string="Fecha" name="group_fecha"
                            context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

