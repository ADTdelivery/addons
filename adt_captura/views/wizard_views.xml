<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard: Registrar Pago -->
    <record id="view_adt_captura_pago_wizard_form" model="ir.ui.view">
        <field name="name">adt.captura.pago.wizard.form</field>
        <field name="model">adt.captura.pago.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Pago de Intervención">
                <group>
                    <group>
                        <field name="captura_id" readonly="1"/>
                        <field name="monto"/>
                    </group>
                    <group>
                        <field name="payment_date"/>
                        <field name="voucher_number"/>
                    </group>
                </group>

                <group>
                    <field name="voucher_file" filename="voucher_filename" required="1"/>
                    <field name="voucher_filename" invisible="1"/>
                </group>

                <group>
                    <field name="notes" placeholder="Observaciones adicionales..."/>
                </group>

                <footer>
                    <button string="Registrar Pago"
                            name="action_registrar"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard: Retener Vehículo -->
    <record id="view_adt_captura_retencion_wizard_form" model="ir.ui.view">
        <field name="name">adt.captura.retencion.wizard.form</field>
        <field name="model">adt.captura.retencion.wizard</field>
        <field name="arch" type="xml">
            <form string="Disolución de Contrato">
                <group>
                    <field name="captura_id" readonly="1"/>
                    <field name="retention_date"/>

                    <field name="retention_reason" string="Motivo de Retención"/>
                    <field name="notes" string="Observaciones Adicionales" attrs="{'readonly': [('retention_reason', '!=', 'otro')]}" />
                </group>

                <footer>
                    <button string="Inciar"
                            name="action_retener"
                            type="object"
                            class="btn-danger"
                            confirm="¿Está seguro de iniciar el Proceso de Disolución de Contrato? Esta acción es irreversible."/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <!-- Wizard View: Liberar Vehículo -->
    <record id="view_adt_captura_liberar_wizard_form" model="ir.ui.view">
        <field name="name">adt.captura.liberar.wizard.form</field>
        <field name="model">adt.captura.liberar.wizard</field>
        <field name="arch" type="xml">
            <form string="Liberar Vehículo">
                <group>
                    <field name="liberacion_tipo"/>
                    <field name="observaciones" placeholder="Añadir observaciones..."/>
                </group>
                <footer>
                    <button string="Guardar" type="object" name="confirmar_liberacion" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
