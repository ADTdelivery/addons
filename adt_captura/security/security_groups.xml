<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Grupos de seguridad -->
    <record id="group_captura_capturador" model="res.groups">
        <field name="name">Capturador</field>
        <field name="category_id" ref="base.module_category_operations"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_captura_supervisor" model="res.groups">
        <field name="name">Supervisor de Captura</field>
        <field name="category_id" ref="base.module_category_operations"/>
        <field name="implied_ids" eval="[(4, ref('group_captura_capturador'))]"/>
    </record>

    <record id="group_captura_administrador" model="res.groups">
        <field name="name">Administrador de Captura</field>
        <field name="category_id" ref="base.module_category_operations"/>
        <field name="implied_ids" eval="[(4, ref('group_captura_supervisor'))]"/>
    </record>
</odoo>
