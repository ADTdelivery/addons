<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="dashboard_caja" name="Dashboard de Caja">
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Dashboard de Caja</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
  .dash-wrapper   { max-width: 1400px; margin: 0 auto; padding: 24px 20px 48px; }
  .dash-topbar    { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 28px; }
  .dash-title     { font-size: 1.6rem; font-weight: 700; color: #f8fafc; letter-spacing: -0.3px; }
  .dash-title span{ color: #38bdf8; }
  .dash-subtitle  { font-size: 0.82rem; color: #94a3b8; margin-top: 3px; }
  .period-tabs    { display: flex; gap: 6px; background: #1e293b; border-radius: 12px; padding: 5px; flex-wrap: wrap; }
  .period-btn     { padding: 7px 18px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.82rem; font-weight: 600;
                    background: transparent; color: #94a3b8; transition: all .2s; text-decoration: none; display: inline-block; }
  .period-btn:hover  { background: #334155; color: #e2e8f0; }
  .period-btn.active { background: #0ea5e9; color: #fff; box-shadow: 0 2px 8px rgba(14,165,233,.4); }
  .range-form     { display: flex; gap: 8px; align-items: center; background: #1e293b; padding: 8px 14px; border-radius: 10px; flex-wrap: wrap; }
  .range-form input[type="date"] { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; border-radius: 6px; padding: 5px 10px; font-size: 0.82rem; outline: none; }
  .range-form input[type="date"]:focus { border-color: #38bdf8; }
  .range-form button { padding: 6px 16px; border-radius: 6px; border: none; background: #0ea5e9; color: #fff; cursor: pointer; font-size: 0.82rem; font-weight: 600; transition: background .2s; }
  .range-form button:hover { background: #0284c7; }
  .range-label    { font-size: 0.78rem; color: #64748b; }
  .kpi-grid       { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 28px; }
  .kpi-card       { background: #1e293b; border-radius: 16px; padding: 22px 24px; position: relative; overflow: hidden;
                    border: 1px solid #334155; transition: transform .2s, box-shadow .2s; }
  .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,.35); }
  .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 16px 16px 0 0; }
  .kpi-card.ingreso::before  { background: linear-gradient(90deg, #22c55e, #4ade80); }
  .kpi-card.egreso::before   { background: linear-gradient(90deg, #ef4444, #f87171); }
  .kpi-card.saldo::before    { background: linear-gradient(90deg, #0ea5e9, #38bdf8); }
  .kpi-card.ops::before      { background: linear-gradient(90deg, #a855f7, #c084fc); }
  .kpi-card.promedio::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
  .kpi-icon  { width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 14px; }
  .kpi-card.ingreso  .kpi-icon { background: rgba(34,197,94,.15); }
  .kpi-card.egreso   .kpi-icon { background: rgba(239,68,68,.15); }
  .kpi-card.saldo    .kpi-icon { background: rgba(14,165,233,.15); }
  .kpi-card.ops      .kpi-icon { background: rgba(168,85,247,.15); }
  .kpi-card.promedio .kpi-icon { background: rgba(245,158,11,.15); }
  .kpi-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .6px; color: #64748b; margin-bottom: 6px; }
  .kpi-value { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.5px; line-height: 1; }
  .kpi-card.ingreso  .kpi-value { color: #4ade80; }
  .kpi-card.egreso   .kpi-value { color: #f87171; }
  .kpi-card.saldo    .kpi-value { color: #38bdf8; }
  .kpi-card.ops      .kpi-value { color: #c084fc; }
  .kpi-card.promedio .kpi-value { color: #fbbf24; }
  .kpi-sub   { font-size: 0.73rem; color: #64748b; margin-top: 6px; }
  .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
  @media (max-width: 900px) { .charts-grid { grid-template-columns: 1fr; } }
  .panel       { background: #1e293b; border-radius: 16px; padding: 22px 24px; border: 1px solid #334155; }
  .panel-title { font-size: 0.88rem; font-weight: 700; color: #cbd5e1; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
  .panel-title .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .donut-wrap  { display: flex; align-items: center; gap: 28px; justify-content: center; flex-wrap: wrap; }
  .donut-legend { display: flex; flex-direction: column; gap: 12px; }
  .legend-item { display: flex; align-items: center; gap: 10px; font-size: 0.82rem; }
  .legend-dot  { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }
  .legend-val  { font-weight: 700; color: #f8fafc; }
  .legend-lbl  { color: #64748b; font-size: 0.75rem; }
  .table-wrap  { overflow-x: auto; }
  table        { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
  thead tr     { border-bottom: 1px solid #334155; }
  th           { padding: 10px 14px; text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: .5px; color: #64748b; font-weight: 600; white-space: nowrap; }
  tbody tr     { border-bottom: 1px solid #1e293b; transition: background .15s; }
  tbody tr:hover { background: #273549; }
  td           { padding: 10px 14px; color: #cbd5e1; white-space: nowrap; }
  .td-monto-pos { color: #4ade80; font-weight: 700; }
  .td-monto-neg { color: #f87171; font-weight: 700; }
  .badge-ingreso { background: rgba(34,197,94,.12); color: #4ade80; border-radius: 6px; padding: 2px 8px; font-size: 0.7rem; font-weight: 700; }
  .badge-egreso  { background: rgba(239,68,68,.12); color: #f87171; border-radius: 6px; padding: 2px 8px; font-size: 0.7rem; font-weight: 700; }
  .empty-state { text-align: center; padding: 48px 20px; color: #475569; }
  .empty-state .icon { font-size: 3rem; margin-bottom: 10px; }
  .table-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
  .search-input { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; border-radius: 8px; padding: 7px 12px; font-size: 0.82rem; outline: none; width: 220px; }
  .search-input:focus { border-color: #38bdf8; }
  .filter-select { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; border-radius: 8px; padding: 7px 10px; font-size: 0.82rem; outline: none; cursor: pointer; }
  @media (max-width: 600px) { .kpi-value { font-size: 1.35rem; } .dash-title { font-size: 1.2rem; } .period-btn { padding: 6px 12px; font-size: 0.75rem; } }
</style>
</head>
<body>
<div class="dash-wrapper">

  <div class="dash-topbar">
    <div>
      <div class="dash-title">&#x1F4CA; Dashboard de <span>Caja</span></div>
      <div class="dash-subtitle">
        Periodo: <t t-esc="periodo_activo.capitalize()"/> &#xB7;
        <t t-esc="fecha_inicio_val"/> &#x2014; <t t-esc="fecha_fin_val"/>
      </div>
    </div>
    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
      <div class="period-tabs">
        <a t-attf-href="/web/dashboard/caja?periodo=dia"
           t-attf-class="period-btn#{' active' if periodo_activo == 'dia' else ''}">Hoy</a>
        <a t-attf-href="/web/dashboard/caja?periodo=semana"
           t-attf-class="period-btn#{' active' if periodo_activo == 'semana' else ''}">Semana</a>
        <a t-attf-href="/web/dashboard/caja?periodo=mes"
           t-attf-class="period-btn#{' active' if periodo_activo == 'mes' else ''}">Mes</a>
        <a t-attf-href="/web/dashboard/caja?periodo=rango"
           t-attf-class="period-btn#{' active' if periodo_activo == 'rango' else ''}">Rango</a>
      </div>
      <!-- Range picker: visible siempre que periodo=rango -->
      <t t-if="periodo_activo == 'rango'">
        <form class="range-form" method="GET" action="/web/dashboard/caja" style="margin-bottom:0;">
          <input type="hidden" name="periodo" value="rango"/>
          <span class="range-label">Desde</span>
          <input type="date" name="fecha_inicio" t-att-value="fecha_inicio_input" required="required"/>
          <span class="range-label">Hasta</span>
          <input type="date" name="fecha_fin" t-att-value="fecha_fin_input" required="required"/>
          <button type="submit">Aplicar</button>
        </form>
      </t>
    </div>
  </div>

  <div class="kpi-grid">
    <div class="kpi-card ingreso">
      <div class="kpi-icon">&#x1F4B0;</div>
      <div class="kpi-label">Total Ingresos</div>
      <div class="kpi-value">S/ <t t-esc="'{:,.2f}'.format(total_ingresos)"/></div>
      <div class="kpi-sub">Montos positivos del periodo</div>
    </div>
    <div class="kpi-card egreso">
      <div class="kpi-icon">&#x1F4B8;</div>
      <div class="kpi-label">Total Egresos</div>
      <div class="kpi-value">S/ <t t-esc="'{:,.2f}'.format(total_egresos)"/></div>
      <div class="kpi-sub">Montos negativos del periodo</div>
    </div>
    <div class="kpi-card saldo">
      <div class="kpi-icon">&#x2696;</div>
      <div class="kpi-label">Saldo Neto</div>
      <div class="kpi-value">S/ <t t-esc="'{:,.2f}'.format(saldo_neto)"/></div>
      <div class="kpi-sub">Ingresos &#x2212; Egresos</div>
    </div>
    <div class="kpi-card ops">
      <div class="kpi-icon">&#x1F522;</div>
      <div class="kpi-label">Operaciones</div>
      <div class="kpi-value"><t t-esc="total_operaciones"/></div>
      <div class="kpi-sub">Registros en el periodo</div>
    </div>
    <div class="kpi-card promedio">
      <div class="kpi-icon">&#x1F4C8;</div>
      <div class="kpi-label">Prom. Diario Ingresos</div>
      <div class="kpi-value">S/ <t t-esc="'{:,.2f}'.format(promedio_diario_ingresos)"/></div>
      <t t-if="dia_mayor_ingreso">
        <div class="kpi-sub">Mayor: <t t-esc="dia_mayor_ingreso"/></div>
      </t>
    </div>
  </div>

  <div class="charts-grid">
    <div class="panel">
      <div class="panel-title">
        <span class="dot" style="background:#38bdf8;"></span>
        Flujo diario de Caja
      </div>
      <t t-if="datos_grafico">
        <div id="barChartSvg" style="width:100%;min-height:220px;"></div>
      </t>
      <t t-else="">
        <div class="empty-state"><div class="icon">&#x1F4ED;</div><div>Sin datos para el periodo</div></div>
      </t>
    </div>

    <div class="panel">
      <div class="panel-title">
        <span class="dot" style="background:#a855f7;"></span>
        Distribucion Ingresos vs Egresos
      </div>
      <t t-if="total_ingresos or total_egresos">
        <div class="donut-wrap">
          <div id="donutChartSvg" style="width:190px;height:190px;flex-shrink:0;"></div>
          <div class="donut-legend">
            <div class="legend-item">
              <div class="legend-dot" style="background:#4ade80;"></div>
              <div>
                <div class="legend-val">S/ <t t-esc="'{:,.2f}'.format(total_ingresos)"/></div>
                <div class="legend-lbl">Ingresos</div>
              </div>
            </div>
            <div class="legend-item">
              <div class="legend-dot" style="background:#f87171;"></div>
              <div>
                <div class="legend-val">S/ <t t-esc="'{:,.2f}'.format(total_egresos)"/></div>
                <div class="legend-lbl">Egresos</div>
              </div>
            </div>
            <div class="legend-item">
              <div class="legend-dot" style="background:#38bdf8;"></div>
              <div>
                <div class="legend-val">S/ <t t-esc="'{:,.2f}'.format(saldo_neto)"/></div>
                <div class="legend-lbl">Saldo neto</div>
              </div>
            </div>
          </div>
        </div>
      </t>
      <t t-else="">
        <div class="empty-state"><div class="icon">&#x1F369;</div><div>Sin datos para el periodo</div></div>
      </t>
    </div>
  </div>

  <div class="panel">
    <div class="table-header">
      <div class="panel-title" style="margin-bottom:0;">
        <span class="dot" style="background:#f59e0b;"></span>
        Detalle de movimientos
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input class="search-input" type="text" id="tableSearch" placeholder="Buscar descripcion..." oninput="filterTable()"/>
        <select class="filter-select" id="tableFilter" onchange="filterTable()">
          <option value="all">Todos</option>
          <option value="ingreso">Solo ingresos</option>
          <option value="egreso">Solo egresos</option>
        </select>
      </div>
    </div>
    <div class="table-wrap" style="margin-top:16px;">
      <t t-if="registros">
        <table id="movTable">
          <thead>
            <tr>
              <th>#</th><th>Fecha</th><th>Descripcion</th><th>Monto (S/)</th><th>N Operacion</th><th>Tipo</th>
            </tr>
          </thead>
          <tbody>
            <t t-foreach="registros" t-as="r">
              <tr t-attf-data-tipo="#{r['monto'] &gt; 0 and 'ingreso' or 'egreso'}"
                  t-attf-data-desc="#{r['descripcion'].lower()}">
                <td style="color:#475569;"><t t-esc="r_index + 1"/></td>
                <td><t t-esc="r['fecha']"/></td>
                <td><t t-esc="r['descripcion']"/></td>
                <td t-attf-class="#{r['monto'] &gt; 0 and 'td-monto-pos' or 'td-monto-neg'}">
                  S/ <t t-esc="'{:,.2f}'.format(abs(r['monto']))"/>
                </td>
                <td style="color:#94a3b8;"><t t-esc="r['numero_operacion']"/></td>
                <td>
                  <t t-if="r['monto'] &gt; 0"><span class="badge-ingreso">Ingreso</span></t>
                  <t t-else=""><span class="badge-egreso">Egreso</span></t>
                </td>
              </tr>
            </t>
          </tbody>
        </table>
      </t>
      <t t-else="">
        <div class="empty-state">
          <div class="icon">&#x1F4C2;</div>
          <div>No hay movimientos en este periodo</div>
        </div>
      </t>
    </div>
  </div>

</div>

<!-- Data island: datos embebidos en atributos HTML seguros -->
<div id="dashData"
     style="display:none;"
     t-att-data-grafico="datos_grafico_json"
     t-att-data-ingresos="total_ingresos or 0"
     t-att-data-egresos="total_egresos or 0">
</div>

<script>
(function(){
  'use strict';

  var el = document.getElementById('dashData');
  var graficoDatos  = [];
  var totalIngresos = 0;
  var totalEgresos  = 0;
  if (el) {
    try { graficoDatos  = JSON.parse(el.getAttribute('data-grafico') || '[]'); } catch(e){}
    totalIngresos = parseFloat(el.getAttribute('data-ingresos') || '0') || 0;
    totalEgresos  = parseFloat(el.getAttribute('data-egresos')  || '0') || 0;
  }

  /* TABLE FILTER */
  window.filterTable = function(){
    var search = (document.getElementById('tableSearch').value || '').toLowerCase();
    var filter = document.getElementById('tableFilter').value;
    document.querySelectorAll('#movTable tbody tr').forEach(function(row){
      var tipo = row.getAttribute('data-tipo') || '';
      var desc = row.getAttribute('data-desc') || '';
      row.style.display = ((filter === 'all' || tipo === filter) &amp;&amp; (!search || desc.indexOf(search) !== -1)) ? '' : 'none';
    });
  };

  function fmt(n){ return 'S/ ' + parseFloat(n).toLocaleString('es-PE', {minimumFractionDigits:2, maximumFractionDigits:2}); }

  /* ── BAR CHART (SVG puro) ───────────────────────────────── */
  function buildBarChart() {
    var container = document.getElementById('barChartSvg');
    if (!container || !graficoDatos.length) return;

    var W = container.clientWidth || 560, H = 220;
    var padL = 64, padR = 16, padT = 20, padB = 40;
    var chartW = W - padL - padR;
    var chartH = H - padT - padB;

    var maxVal = 0;
    graficoDatos.forEach(function(d){
      if (d.ingresos > maxVal) maxVal = d.ingresos;
      if (d.egresos  > maxVal) maxVal = d.egresos;
    });
    if (maxVal === 0) maxVal = 1;

    var n = graficoDatos.length;
    var groupW = chartW / n;
    var barW = Math.max(4, Math.min(20, groupW * 0.35));
    var parts = [];

    parts.push('&lt;svg xmlns="http://www.w3.org/2000/svg" width="100%" height="' + H + '" viewBox="0 0 ' + W + ' ' + H + '"&gt;');

    /* Grid lines */
    for (var s = 0; s &lt;= 4; s++) {
      var yg = padT + chartH - (s / 4) * chartH;
      var val = (s / 4) * maxVal;
      var valLbl = val &gt;= 1000 ? (val/1000).toFixed(1)+'k' : val.toFixed(0);
      parts.push('&lt;line x1="'+padL+'" y1="'+yg+'" x2="'+(W-padR)+'" y2="'+yg+'" stroke="rgba(51,65,85,.5)" stroke-width="1"/&gt;');
      parts.push('&lt;text x="'+(padL-6)+'" y="'+(yg+4)+'" text-anchor="end" font-size="9" fill="#64748b"&gt;'+valLbl+'&lt;/text&gt;');
    }

    /* Bars */
    graficoDatos.forEach(function(d, i){
      var cx = padL + (i + 0.5) * groupW;
      var hI = (d.ingresos / maxVal) * chartH;
      var hE = (d.egresos  / maxVal) * chartH;
      var xI = cx - barW - 1;
      var xE = cx + 1;
      if (hI &gt; 0) {
        parts.push('&lt;rect x="'+xI+'" y="'+(padT+chartH-hI)+'" width="'+barW+'" height="'+hI+'" rx="3" fill="rgba(74,222,128,.8)"/&gt;');
      }
      if (hE &gt; 0) {
        parts.push('&lt;rect x="'+xE+'" y="'+(padT+chartH-hE)+'" width="'+barW+'" height="'+hE+'" rx="3" fill="rgba(248,113,113,.8)"/&gt;');
      }
      if (i % Math.ceil(n / 8) === 0) {
        var lbl = d.fecha.slice(0, 5);
        parts.push('&lt;text x="'+cx+'" y="'+(H-6)+'" text-anchor="middle" font-size="9" fill="#64748b"&gt;'+lbl+'&lt;/text&gt;');
      }
    });

    /* Legend */
    parts.push('&lt;rect x="'+padL+'" y="4" width="10" height="10" rx="2" fill="rgba(74,222,128,.8)"/&gt;');
    parts.push('&lt;text x="'+(padL+13)+'" y="13" font-size="10" fill="#94a3b8"&gt;Ingresos&lt;/text&gt;');
    parts.push('&lt;rect x="'+(padL+72)+'" y="4" width="10" height="10" rx="2" fill="rgba(248,113,113,.8)"/&gt;');
    parts.push('&lt;text x="'+(padL+85)+'" y="13" font-size="10" fill="#94a3b8"&gt;Egresos&lt;/text&gt;');
    parts.push('&lt;/svg&gt;');

    container.innerHTML = parts.join('').replace(/&lt;/g,'\x3C').replace(/&gt;/g,'\x3E');
  }

  /* ── DONUT CHART (SVG puro) ─────────────────────────────── */
  function buildDonutChart() {
    var container = document.getElementById('donutChartSvg');
    if (!container) return;
    var total = totalIngresos + totalEgresos;
    if (total &lt;= 0) return;

    var R = 70, r = 46, cx = 95, cy = 95, size = 190;
    var circ = 2 * Math.PI * R;
    var ingPct = totalIngresos / total;
    var egrPct = 1 - ingPct;
    var ingLen = ingPct * circ;
    var egrLen = egrPct * circ;
    var offset = circ * 0.25;

    var parts = [];
    parts.push('&lt;svg xmlns="http://www.w3.org/2000/svg" width="'+size+'" height="'+size+'"&gt;');
    parts.push('&lt;circle cx="'+cx+'" cy="'+cy+'" r="'+R+'" fill="none" stroke="#334155" stroke-width="'+(R-r)+'"/&gt;');
    parts.push('&lt;circle cx="'+cx+'" cy="'+cy+'" r="'+R+'" fill="none" stroke="rgba(74,222,128,.85)" stroke-width="'+(R-r)+'"'
      +' stroke-dasharray="'+ingLen+' '+(circ-ingLen)+'"'
      +' stroke-dashoffset="'+offset+'"'
      +' transform="rotate(-90 '+cx+' '+cy+')"/&gt;');
    parts.push('&lt;circle cx="'+cx+'" cy="'+cy+'" r="'+R+'" fill="none" stroke="rgba(248,113,113,.85)" stroke-width="'+(R-r)+'"'
      +' stroke-dasharray="'+egrLen+' '+(circ-egrLen)+'"'
      +' stroke-dashoffset="'+(offset-ingLen)+'"'
      +' transform="rotate(-90 '+cx+' '+cy+')"/&gt;');
    var pct = (ingPct*100).toFixed(0)+'%';
    parts.push('&lt;text x="'+cx+'" y="'+(cy-6)+'" text-anchor="middle" font-size="18" font-weight="700" fill="#4ade80"&gt;'+pct+'&lt;/text&gt;');
    parts.push('&lt;text x="'+cx+'" y="'+(cy+12)+'" text-anchor="middle" font-size="9" fill="#64748b"&gt;ingresos&lt;/text&gt;');
    parts.push('&lt;/svg&gt;');

    container.innerHTML = parts.join('').replace(/&lt;/g,'\x3C').replace(/&gt;/g,'\x3E');
  }

  function init() {
    buildBarChart();
    buildDonutChart();
  }

  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); }
  else { init(); }
  window.addEventListener('resize', buildBarChart);

})();
</script>
</body>
</html>
</template>
</odoo>
