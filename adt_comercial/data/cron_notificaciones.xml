<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Cron: Notificaciones de cuotas próximas a vencer / vencidas
            Horario: 8:00 PM hora Lima / Perú (America/Lima, UTC-5)
                     = 01:00 AM UTC del día siguiente
        -->
        <record id="ir_cron_notificaciones_cuotas" model="ir.cron">
            <field name="name">ADT Comercial: Notificaciones de cuotas</field>
            <field name="model_id" ref="adt_comercial.model_adt_comercial_cuentas"/>
            <field name="state">code</field>
            <field name="code">model.cron_notificar_cuotas()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <!-- Próxima ejecución: 10 mayo 2026 01:00 UTC = 09 mayo 2026 20:00 Lima -->
            <field name="nextcall">2026-05-10 01:00:00</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
