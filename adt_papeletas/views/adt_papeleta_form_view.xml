<odoo>
    <record id="view_adt_papeleta_form" model="ir.ui.view">
        <field name="name">adt.papeleta.form</field>
        <field name="model">adt.papeleta</field>
        <field name="arch" type="xml">
            <form string="Papeleta">
                <header>
                    <!-- show small badge in header when alert exists -->
                    <button name="action_mark_pagado" type="object" string="Marcar como Pagado" class="btn-success" attrs="{'invisible': [('state', '=', 'pagado')]}"/>
                    <button name="action_mark_capturar" type="object" string="Mandar a capturar" class="btn-danger" attrs="{'invisible': [('capturado', '=', True)]}"/>                    <field name="state"   widget="statusbar" statusbar_visible="pendiente,pagado"/>
                </header>

                <!-- ALERTA: mostrado cuando falten <= 5 días para la fecha de captura -->
                <div class="alert alert-danger o_form_warning" role="alert"
                     attrs="{'invisible': [('proximo_a_vencerse','=', False)]}">
                    <strong>⚠ Aviso:</strong>
                    <field name="texto_alerta" readonly="1"/>
                </div>

                <!-- WARNING banner when the papeleta has been marked as captured -->
                <!-- Show only when capturado = True AND recolocada = False -->
                <div class="alert alert-warning o_form_warning" role="alert"
                     attrs="{'invisible': ['|', ('capturado','=', False), ('recolocada','=', True)]}">
                    <strong>⚠ Atención:</strong>
                    El vehículo asociado a esta papeleta ha sido marcado como <em>capturado</em> — esta papeleta será derivada al área de captura para su procesamiento.
                </div>

                <!-- Show only when recolocada = True and not yet pagada -->
                <div class="alert alert-danger o_form_warning" role="alert"
                     attrs="{'invisible': ['|', ('recolocada','=', False), ('state','=', 'pagado')]}">
                    <strong>⚠ Atención:</strong>
                    Este vehículo ya fue <em>recolocado</em>, pero la papeleta asociada aún está pendiente de pago.
                </div>


                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="vehicle_id"/>
                        </group>
                        <group>
                            <field name="fecha_papeleta"/>
                            <field name="monto"/>
                        </group>
                    </group>

                    <group>
                        <field name="payment_method"/>
                    </group>

                    <group>
                        <field name="detalle" colspan="2"/>
                    </group>

                    <group string="Evidencias">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1" string="Evidencias (Fotos/PDFs)"/>
                    </group>

                    <!-- Sección de cuotas: visible cuando el estado sea 'fraccionado' o 'pagado' -->
                    <!-- Controlada por el campo computado show_fraccionamiento -->
                    <group attrs="{'invisible': [('payment_method', '!=', 'fraccionado')]}" string="Fraccionamiento">
                        <field name="cantidad_cuotas"/>
                        <field name="fecha_inicio_cuotas"/>
                        <button name="action_generar_cuotas" type="object" string="Generar cuotas" class="oe_highlight"/>
                        <field name="cuotas_ids">
                            <tree string="Cuotas">
                                <field name="name"/>
                                <field name="due_date"/>
                                <field name="amount"/>
                                <field name="state"/>
                            </tree>
                            <form string="Cuota">
                                <group>
                                    <field name="name"/>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                </group>
                            </form>
                        </field>
                    </group>

                    <group string="Prórroga">
                        <field name="tiene_prorroga"/>
                        <field name="dias_prorroga" attrs="{'invisible': [('tiene_prorroga', '=', False)]}"/>
                        <field name="motivo_prorroga" attrs="{'invisible': [('tiene_prorroga', '=', False)]}"/>
                    </group>

                    <group string="Control de Vencimiento">
                        <field name="fecha_captura" readonly="1"/>
                        <field name="fecha_vencimiento_final" readonly="1"/>
                    </group>

                    <field name="proximo_a_vencerse" invisible="1"/>
                    <field name="texto_alerta" invisible="1"/>
                    <field name="show_fraccionamiento" invisible="1"/>
                    <field name="capturado" invisible="1"/>
                    <field name="recolocada" invisible="1"/>

                </sheet>

                <!-- Chatter / History -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <record id="view_adt_papeleta_tree" model="ir.ui.view">
        <field name="name">adt.papeleta.tree</field>
        <field name="model">adt.papeleta</field>
        <field name="arch" type="xml">
            <tree decoration-danger="proximo_a_vencerse">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="fecha_papeleta"/>
                <field name="monto"/>
                <field name="payment_method"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'pagado'"
                       decoration-warning="state == 'fraccionado'"
                       decoration-info="state == 'pendiente'"/>
                <field name="fecha_vencimiento_final"/>
                <!-- Mostrar días y texto de alerta para visibilidad rápida -->
                <field name="dias_para_captura" string="Días para Captura"/>
                <field name="alert_badge" string="Alerta" widget="adt_alert_badge"/>
                 <!-- required by decoration-danger: include the field (can be invisible) -->
                <field name="proximo_a_vencerse" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="action_adt_papeletas" model="ir.actions.act_window">
        <field name="name">Papeletas</field>
        <field name="res_model">adt.papeleta</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_adt_papeleta_tree"/>
    </record>

    <!-- Action: Papeletas Pendientes -->
    <record id="action_adt_papeletas_pendientes" model="ir.actions.act_window">
        <field name="name">Papeletas Pendientes</field>
        <field name="res_model">adt.papeleta</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_adt_papeleta_tree"/>
        <field name="domain">[('state','=','pendiente')]</field>
    </record>

    <!-- Action: Papeletas Pagadas -->
    <record id="action_adt_papeletas_pagadas" model="ir.actions.act_window">
        <field name="name">Papeletas Pagadas</field>
        <field name="res_model">adt.papeleta</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_adt_papeleta_tree"/>
        <field name="domain">[('state','=','pagado')]</field>
    </record>

    <!-- Menus under root -->
    <menuitem id="menu_adt_papeletas_root" name="Papeletas" sequence="95"/>
    <menuitem id="menu_adt_papeletas_pendientes" name="Pendientes" parent="menu_adt_papeletas_root" action="action_adt_papeletas_pendientes" sequence="5"/>
    <menuitem id="menu_adt_papeletas_pagadas" name="Pagadas" parent="menu_adt_papeletas_root" action="action_adt_papeletas_pagadas" sequence="10"/>
    <menuitem id="menu_adt_papeletas_todas" name="Todas" parent="menu_adt_papeletas_root" action="action_adt_papeletas" sequence="15"/>
</odoo>
