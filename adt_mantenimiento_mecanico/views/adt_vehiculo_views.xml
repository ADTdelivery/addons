<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Tree de Vehículos -->
    <record id="view_adt_vehiculo_tree" model="ir.ui.view">
        <field name="name">adt.vehiculo.tree</field>
        <field name="model">adt.vehiculo</field>
        <field name="arch" type="xml">
            <tree string="Vehículos"
                  decoration-warning="alerta_mantenimiento"
                  decoration-danger="alerta_credito"
                  multi_edit="1">
                <field name="name"/>
                <field name="tipo" widget="badge"/>
                <field name="placa"/>
                <field name="marca_id"/>
                <field name="modelo"/>
                <field name="ano"/>
                <field name="cliente_id"/>
                <field name="kilometraje"/>
                <field name="ultima_fecha_servicio"/>
                <field name="cantidad_ordenes"/>
                <field name="alerta_mantenimiento" invisible="1"/>
                <field name="alerta_credito" invisible="1"/>
                <button name="action_ver_historial"
                        type="object"
                        icon="fa-history"
                        title="Ver Historial"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form de Vehículos -->
    <record id="view_adt_vehiculo_form" model="ir.ui.view">
        <field name="name">adt.vehiculo.form</field>
        <field name="model">adt.vehiculo</field>
        <field name="arch" type="xml">
            <form string="Vehículo">
                <sheet>
                    <!-- Campos invisibles necesarios para attrs -->
                    <field name="alerta_mantenimiento" invisible="1"/>
                    <field name="alerta_credito" invisible="1"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_historial"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-wrench">
                            <field name="cantidad_ordenes" widget="statinfo" string="Órdenes"/>
                        </button>
                    </div>

                    <!-- Alertas -->
                    <div class="alert alert-warning"
                         attrs="{'invisible': [('alerta_mantenimiento', '=', False)]}">
                        <i class="fa fa-exclamation-triangle"/>
                        <strong>Alerta:</strong> Este vehículo requiere mantenimiento
                    </div>

                    <div class="alert alert-danger"
                         attrs="{'invisible': [('alerta_credito', '=', False)]}">
                        <i class="fa fa-exclamation-circle"/>
                        <strong>Atención:</strong> Cliente con crédito atrasado
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información General">
                            <field name="tipo" widget="radio"/>
                            <field name="marca_id" options="{'no_create': False, 'no_open': False}"/>
                            <field name="modelo"/>
                            <field name="ano"/>
                            <field name="color"/>
                        </group>
                        <group string="Identificación">
                            <field name="placa"/>
                            <field name="vin_chasis"/>
                            <field name="numero_motor"/>
                        </group>
                    </group>

                    <group>
                        <group string="Especificaciones">
                            <field name="combustible"/>
                            <field name="cilindraje"/>
                            <field name="kilometraje"/>
                            <field name="ultimo_kilometraje" readonly="1"/>
                        </group>
                        <group string="Propietario">
                            <field name="cliente_id"/>
                            <field name="fecha_compra"/>
                        </group>
                    </group>

                    <group string="Documentación">
                        <group>
                            <field name="poliza_seguro"/>
                            <field name="estado_documentacion" widget="badge"/>
                        </group>
                        <group>
                            <field name="ultima_fecha_servicio" readonly="1"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Historial de Mantenimientos" name="historial">
                            <field name="orden_ids">
                                <tree string="Órdenes">
                                    <field name="name"/>
                                    <field name="fecha_ingreso"/>
                                    <field name="tipo_servicio"/>
                                    <field name="state" widget="badge"/>
                                    <field name="total"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Créditos Financieros" name="creditos">
                            <field name="credito_ids">
                                <tree string="Créditos">
                                    <field name="name"/>
                                    <field name="empresa_financiera"/>
                                    <field name="monto_credito"/>
                                    <field name="estado" widget="badge"/>
                                    <field name="fecha_vencimiento"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Kanban de Vehículos -->
    <record id="view_adt_vehiculo_kanban" model="ir.ui.view">
        <field name="name">adt.vehiculo.kanban</field>
        <field name="model">adt.vehiculo</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="placa"/>
                <field name="marca_id"/>
                <field name="cliente_id"/>
                <field name="alerta_mantenimiento"/>
                <field name="alerta_credito"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <strong><field name="name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_card_content">
                                <div class="o_kanban_record_body">
                                    <field name="cliente_id"/>
                                    <br/>
                                    <field name="placa"/>
                                </div>
                            </div>
                            <div class="o_kanban_card_footer">
                                <t t-if="record.alerta_mantenimiento.raw_value">
                                    <span class="badge badge-warning">
                                        <i class="fa fa-warning"/> Mantenimiento
                                    </span>
                                </t>
                                <t t-if="record.alerta_credito.raw_value">
                                    <span class="badge badge-danger">
                                        <i class="fa fa-exclamation"/> Crédito
                                    </span>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista Search de Vehículos -->
    <record id="view_adt_vehiculo_search" model="ir.ui.view">
        <field name="name">adt.vehiculo.search</field>
        <field name="model">adt.vehiculo</field>
        <field name="arch" type="xml">
            <search string="Buscar Vehículos">
                <field name="name" string="Vehículo"
                       filter_domain="['|', '|', ('name', 'ilike', self), ('placa', 'ilike', self), ('vin_chasis', 'ilike', self)]"/>
                <field name="placa"/>
                <field name="marca_id"/>
                <field name="cliente_id"/>
                <filter string="Con Alerta Mantenimiento" name="alerta_mantenimiento" domain="[('alerta_mantenimiento', '=', True)]"/>
                <filter string="Con Alerta Crédito" name="alerta_credito" domain="[('alerta_credito', '=', True)]"/>
                <separator/>
                <filter string="Motocicletas" name="motocicletas" domain="[('tipo', '=', 'motocicleta')]"/>
                <filter string="Mototaxis" name="mototaxis" domain="[('tipo', '=', 'mototaxi')]"/>
                <separator/>
                <filter string="Activos" name="activos" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactivos" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Marca" name="group_marca" context="{'group_by': 'marca_id'}"/>
                    <filter string="Tipo" name="group_tipo" context="{'group_by': 'tipo'}"/>
                    <filter string="Cliente" name="group_cliente" context="{'group_by': 'cliente_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de Vehículos -->
    <record id="action_adt_vehiculo" model="ir.actions.act_window">
        <field name="name">Vehículos</field>
        <field name="res_model">adt.vehiculo</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrar un nuevo vehículo
            </p>
            <p>
                Gestiona el inventario completo de motocicletas y mototaxis.<br/>
                Lleva el control de mantenimientos, historial y alertas.
            </p>
        </field>
    </record>

    <!-- Acción de Marcas de Vehículos -->
    <record id="action_adt_vehiculo_marca" model="ir.actions.act_window">
        <field name="name">Marcas de Vehículos</field>
        <field name="res_model">adt.vehiculo.marca</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrar una nueva marca
            </p>
        </field>
    </record>

</odoo>
