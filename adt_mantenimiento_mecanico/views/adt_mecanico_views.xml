<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Form de Mecánico -->
    <record id="view_adt_mecanico_form" model="ir.ui.view">
        <field name="name">adt.mecanico.form</field>
        <field name="model">adt.mecanico</field>
        <field name="arch" type="xml">
            <form string="Mecánico">
                <header>
                    <field name="estado" widget="statusbar" statusbar_visible="activo,licencia,vacaciones"/>
                </header>
                <sheet>
                    <field name="foto" widget="image" class="oe_avatar"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_trabajos"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-tasks">
                            <field name="trabajos_activos" widget="statinfo" string="Activos"/>
                        </button>
                        <button name="action_ver_trabajos"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-square">
                            <field name="trabajos_completados" widget="statinfo" string="Completados"/>
                        </button>
                        <button name="action_ver_estadisticas"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-line-chart">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="eficiencia_promedio" widget="percentage"/>
                                </span>
                                <span class="o_stat_text">Eficiencia</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre completo del mecánico"/>
                        </h1>
                        <h3>
                            <field name="especialidad"/>
                        </h3>
                    </div>

                    <!-- Alertas -->
                    <div class="alert alert-warning"
                         attrs="{'invisible': [('trabajos_activos', '&lt;', 5)]}">
                        <i class="fa fa-exclamation-triangle"/>
                        <strong>Atención:</strong> Mecánico con alta carga de trabajo (<field name="trabajos_activos"/> trabajos activos)
                    </div>

                    <group>
                        <group string="Información Personal">
                            <field name="dni"/>
                            <field name="user_id" options="{'no_create': True}"/>
                            <field name="fecha_nacimiento"/>
                            <field name="edad" readonly="1"/>
                            <field name="telefono"/>
                            <field name="email"/>
                        </group>
                        <group string="Información Laboral">
                            <field name="fecha_ingreso"/>
                            <field name="estado" widget="badge"/>
                            <field name="nivel_experiencia" widget="badge"/>
                            <field name="anos_experiencia"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group string="Especialización">
                        <group>
                            <field name="especialidad"/>
                            <field name="marcas_especializadas"/>
                        </group>
                        <group>
                            <field name="certificaciones" placeholder="Lista de certificaciones..."/>
                        </group>
                    </group>

                    <group string="Métricas de Desempeño">
                        <group>
                            <field name="eficiencia_promedio" widget="progressbar"/>
                            <field name="tasa_retrabajo" widget="percentage"/>
                            <field name="horas_trabajadas_total"/>
                        </group>
                        <group>
                            <field name="comision_acumulada"/>
                        </group>
                    </group>

                    <group string="Firma Digital">
                        <field name="firma_digital" widget="image"/>
                    </group>

                    <group string="Dirección">
                        <field name="direccion" placeholder="Dirección completa..."/>
                    </group>

                    <notebook>
                        <page string="Trabajos Asignados" name="trabajos">
                            <field name="trabajo_ids">
                                <tree decoration-bf="state == 'in_progress'">
                                    <field name="orden_id"/>
                                    <field name="descripcion"/>
                                    <field name="prioridad" widget="priority"/>
                                    <field name="tiempo_estimado" widget="float_time"/>
                                    <field name="horas_reales" widget="float_time"/>
                                    <field name="eficiencia" widget="percentage"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Tree de Mecánicos -->
    <record id="view_adt_mecanico_tree" model="ir.ui.view">
        <field name="name">adt.mecanico.tree</field>
        <field name="model">adt.mecanico</field>
        <field name="arch" type="xml">
            <tree string="Mecánicos" decoration-warning="trabajos_activos &gt;= 5">
                <field name="name"/>
                <field name="dni"/>
                <field name="especialidad"/>
                <field name="nivel_experiencia" widget="badge"/>
                <field name="trabajos_activos"/>
                <field name="eficiencia_promedio" widget="percentage"/>
                <field name="comision_acumulada"/>
                <field name="estado" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- Vista Kanban de Mecánicos -->
    <record id="view_adt_mecanico_kanban" model="ir.ui.view">
        <field name="name">adt.mecanico.kanban</field>
        <field name="model">adt.mecanico</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="foto"/>
                <field name="especialidad"/>
                <field name="trabajos_activos"/>
                <field name="eficiencia_promedio"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('adt.mecanico', 'foto', record.id.raw_value)" alt="Foto"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="especialidad"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="badge badge-info">
                                            <field name="trabajos_activos"/> trabajos
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="eficiencia_promedio" widget="percentage"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista Search de Mecánicos -->
    <record id="view_adt_mecanico_search" model="ir.ui.view">
        <field name="name">adt.mecanico.search</field>
        <field name="model">adt.mecanico</field>
        <field name="arch" type="xml">
            <search string="Buscar Mecánicos">
                <field name="name"/>
                <field name="dni"/>
                <field name="especialidad"/>
                <filter string="Activos" name="activos" domain="[('estado', '=', 'activo')]"/>
                <filter string="Con Alta Carga" name="alta_carga" domain="[('trabajos_activos', '&gt;=', 5)]"/>
                <separator/>
                <filter string="Senior" name="senior" domain="[('nivel_experiencia', '=', 'senior')]"/>
                <filter string="Experto" name="experto" domain="[('nivel_experiencia', '=', 'experto')]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Especialidad" name="group_especialidad" context="{'group_by': 'especialidad'}"/>
                    <filter string="Nivel" name="group_nivel" context="{'group_by': 'nivel_experiencia'}"/>
                    <filter string="Estado" name="group_estado" context="{'group_by': 'estado'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de Mecánicos -->
    <record id="action_adt_mecanico" model="ir.actions.act_window">
        <field name="name">Mecánicos</field>
        <field name="res_model">adt.mecanico</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrar un nuevo mecánico
            </p>
            <p>
                Gestiona el equipo de mecánicos del taller.<br/>
                Controla carga de trabajo, eficiencia y comisiones.
            </p>
        </field>
    </record>

</odoo>
