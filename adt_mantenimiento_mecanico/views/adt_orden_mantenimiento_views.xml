<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Form de Orden de Mantenimiento -->
    <record id="view_adt_orden_mantenimiento_form" model="ir.ui.view">
        <field name="name">adt.orden.mantenimiento.form</field>
        <field name="model">adt.orden.mantenimiento</field>
        <field name="arch" type="xml">
            <form string="Orden de Mantenimiento">
                <header>
                    <button name="action_iniciar_inspeccion" type="object" string="Iniciar Inspección"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_iniciar_diagnostico" type="object" string="Diagnóstico"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'inspeccion')]}"/>
                    <button name="action_generar_cotizacion" type="object" string="Generar Cotización"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'diagnostico')]}"/>
                    <button name="action_aprobar" type="object" string="Aprobar"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'cotizacion')]}"/>
                    <button name="action_iniciar_trabajos" type="object" string="Iniciar Trabajos"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'aprobado')]}"/>
                    <button name="action_control_calidad" type="object" string="Control Calidad"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'in_progress')]}"/>
                    <button name="action_completar" type="object" string="Completar"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'quality_check')]}"/>
                    <button name="action_facturar" type="object" string="Facturar"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'done')]}"/>
                    <button name="action_entregar" type="object" string="Entregar"
                            class="oe_highlight" attrs="{'invisible': [('state', '!=', 'invoiced')]}"/>
                    <button name="action_cancelar" type="object" string="Cancelar"
                            confirm="¿Está seguro de cancelar esta orden?"
                            attrs="{'invisible': [('state', 'in', ['done', 'invoiced', 'delivered', 'cancelled'])]}"/>
                    <button name="action_imprimir_orden" type="object" string="Imprimir" icon="fa-print"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,inspeccion,diagnostico,cotizacion,aprobado,in_progress,quality_check,done,invoiced,delivered"/>
                </header>

                <sheet>
                    <!-- Campos invisibles necesarios para attrs -->
                    <field name="alerta_credito_cliente" invisible="1"/>
                    <field name="alerta_orden_previa" invisible="1"/>

                    <!-- Alertas -->
                    <div class="alert alert-danger" attrs="{'invisible': [('alerta_credito_cliente', '=', False)]}">
                        <i class="fa fa-exclamation-circle"/>
                        <strong>Alerta:</strong> Cliente con crédito atrasado
                    </div>

                    <div class="alert alert-warning" attrs="{'invisible': [('alerta_orden_previa', '=', False)]}">
                        <i class="fa fa-info-circle"/>
                        <strong>Información:</strong> Existe trabajo similar en los últimos 30 días
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información General">
                            <field name="fecha_ingreso"/>
                            <field name="tipo_servicio" widget="radio" options="{'horizontal': true}"/>
                            <field name="prioridad" widget="priority"/>
                            <field name="asesor_id"/>
                        </group>
                        <group string="Cliente y Vehículo">
                            <field name="cliente_id" options="{'no_create': False}"/>
                            <field name="vehiculo_id" domain="[('cliente_id', '=', cliente_id)]"
                                   options="{'no_create': False}"/>
                            <field name="kilometraje"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Inspección" name="inspeccion" attrs="{'invisible': [('state', '=', 'draft')]}">
                            <group>
                                <field name="inspeccion_id"/>
                                <button name="action_iniciar_inspeccion" type="object"
                                        string="Ver/Crear Inspección"
                                        icon="fa-clipboard-list"
                                        attrs="{'invisible': [('inspeccion_id', '!=', False)]}"/>
                            </group>
                        </page>

                        <page string="Control de Fluidos" name="fluidos" attrs="{'invisible': [('state', 'in', ['draft'])]}">
                            <field name="control_fluidos_id"/>
                        </page>

                        <page string="Diagnóstico" name="diagnostico" attrs="{'invisible': [('state', 'in', ['draft', 'inspeccion'])]}">
                            <field name="diagnostico_id"/>
                        </page>

                        <page string="Trabajos" name="trabajos" attrs="{'invisible': [('state', 'in', ['draft', 'inspeccion'])]}">
                            <field name="trabajo_ids">
                                <tree editable="bottom" decoration-success="state == 'done'" decoration-info="state == 'in_progress'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="descripcion"/>
                                    <field name="tipo"/>
                                    <field name="prioridad" widget="priority"/>
                                    <field name="mecanico_id"/>
                                    <field name="tiempo_estimado" widget="float_time"/>
                                    <field name="horas_reales" widget="float_time"/>
                                    <field name="eficiencia" widget="percentage"/>
                                    <field name="autorizado" widget="boolean_toggle"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="cantidad_trabajos"/>
                            </group>
                        </page>

                        <page string="Repuestos" name="repuestos" attrs="{'invisible': [('state', 'in', ['draft', 'inspeccion'])]}">
                            <field name="repuesto_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="descripcion"/>
                                    <field name="tipo_repuesto"/>
                                    <field name="cantidad"/>
                                    <field name="stock_disponible" readonly="1"/>
                                    <field name="precio_unitario"/>
                                    <field name="descuento"/>
                                    <field name="subtotal" sum="Total Repuestos"/>
                                    <field name="autorizado" widget="boolean_toggle"/>
                                    <field name="state" invisible="1"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Mano de Obra" name="mano_obra" attrs="{'invisible': [('state', 'in', ['draft', 'inspeccion'])]}">
                            <field name="mano_obra_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="mecanico_id"/>
                                    <field name="complejidad"/>
                                    <field name="horas_estimadas" widget="float_time"/>
                                    <field name="horas_reales" widget="float_time"/>
                                    <field name="precio_hora_final"/>
                                    <field name="eficiencia" widget="percentage"/>
                                    <field name="subtotal" sum="Total Mano de Obra"/>
                                    <field name="comision_total"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Control de Calidad" name="calidad" attrs="{'invisible': [('state', 'in', ['draft', 'inspeccion', 'diagnostico'])]}">
                            <group>
                                <field name="control_calidad_id"/>
                                <field name="control_calidad_aprobado" readonly="1"/>
                            </group>
                        </page>

                        <page string="Costos y Facturación" name="costos">
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_repuestos"/>
                                <field name="total_mano_obra"/>
                                <field name="descuento"/>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <field name="subtotal"/>
                                </div>
                                <field name="impuesto" string="IGV (18%)"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="total"/>
                                </div>
                                <field name="total" nolabel="1" class="oe_subtotal_footer_separator"/>
                            </group>

                            <group>
                                <group string="Facturación">
                                    <field name="factura_id" readonly="1"/>
                                    <field name="fecha_factura" readonly="1"/>
                                </group>
                                <group string="Estado Final">
                                    <field name="estado_final"/>
                                    <field name="fecha_promesa_entrega"/>
                                    <field name="fecha_entrega_real" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Próxima Revisión" name="proxima" attrs="{'invisible': [('state', 'not in', ['done', 'invoiced', 'delivered'])]}">
                            <field name="proxima_revision_id"/>
                        </page>

                        <page string="Observaciones" name="observaciones">
                            <group>
                                <field name="observaciones" placeholder="Observaciones para el cliente..."/>
                                <field name="notas_internas" placeholder="Notas internas del taller..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista Tree de Órdenes -->
    <record id="view_adt_orden_mantenimiento_tree" model="ir.ui.view">
        <field name="name">adt.orden.mantenimiento.tree</field>
        <field name="model">adt.orden.mantenimiento</field>
        <field name="arch" type="xml">
            <tree string="Órdenes de Mantenimiento"
                  decoration-bf="prioridad in ['alta', 'critica']"
                  decoration-success="state == 'delivered'"
                  decoration-info="state in ['in_progress', 'quality_check']"
                  decoration-warning="state in ['draft', 'cotizacion']"
                  decoration-danger="alerta_credito_cliente">
                <field name="name"/>
                <field name="fecha_ingreso"/>
                <field name="cliente_id"/>
                <field name="vehiculo_placa"/>
                <field name="tipo_servicio"/>
                <field name="prioridad" widget="priority"/>
                <field name="asesor_id"/>
                <field name="cantidad_trabajos"/>
                <field name="total"/>
                <field name="state" widget="badge"/>
                <field name="alerta_credito_cliente" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Vista Kanban de Órdenes -->
    <record id="view_adt_orden_mantenimiento_kanban" model="ir.ui.view">
        <field name="name">adt.orden.mantenimiento.kanban</field>
        <field name="model">adt.orden.mantenimiento</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="cliente_id"/>
                <field name="vehiculo_id"/>
                <field name="prioridad"/>
                <field name="total"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <div class="o_kanban_record_subtitle">
                                            <field name="vehiculo_id"/>
                                        </div>
                                    </div>
                                    <field name="prioridad" widget="priority"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="cliente_id"/>
                                    <div class="text-muted">
                                        <field name="fecha_ingreso" widget="date"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="total" widget="monetary"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="asesor_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista Search de Órdenes -->
    <record id="view_adt_orden_mantenimiento_search" model="ir.ui.view">
        <field name="name">adt.orden.mantenimiento.search</field>
        <field name="model">adt.orden.mantenimiento</field>
        <field name="arch" type="xml">
            <search string="Buscar Órdenes">
                <field name="name" string="Orden" filter_domain="[('name', 'ilike', self)]"/>
                <field name="cliente_id"/>
                <field name="vehiculo_id"/>
                <field name="vehiculo_placa"/>
                <filter string="Borradores" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="En Proceso" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completadas" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Facturadas" name="invoiced" domain="[('state', '=', 'invoiced')]"/>
                <separator/>
                <filter string="Alta Prioridad" name="alta_prioridad" domain="[('prioridad', 'in', ['alta', 'critica'])]"/>
                <filter string="Con Alerta Crédito" name="alerta_credito" domain="[('alerta_credito_cliente', '=', True)]"/>
                <separator/>
                <filter string="Hoy" name="hoy" domain="[('fecha_ingreso', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                <filter string="Esta Semana" name="semana" domain="[('fecha_ingreso', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Asesor" name="group_asesor" context="{'group_by': 'asesor_id'}"/>
                    <filter string="Tipo Servicio" name="group_tipo" context="{'group_by': 'tipo_servicio'}"/>
                    <filter string="Fecha" name="group_fecha" context="{'group_by': 'fecha_ingreso'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de Órdenes -->
    <record id="action_adt_orden_mantenimiento" model="ir.actions.act_window">
        <field name="name">Órdenes de Mantenimiento</field>
        <field name="res_model">adt.orden.mantenimiento</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva orden de mantenimiento
            </p>
            <p>
                Gestiona el flujo completo desde la inspección hasta la entrega.<br/>
                Controla diagnósticos, trabajos, repuestos y calidad.
            </p>
        </field>
    </record>

</odoo>
