<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Secuencia para Órdenes de Mantenimiento -->
    <record id="seq_orden_mantenimiento" model="ir.sequence">
        <field name="name">Orden de Mantenimiento</field>
        <field name="code">adt.orden.mantenimiento</field>
        <field name="prefix">OM-</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

    <!-- Secuencia para Trabajos -->
    <record id="seq_trabajo" model="ir.sequence">
        <field name="name">Trabajo</field>
        <field name="code">adt.trabajo</field>
        <field name="prefix">TRAB-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

</odoo>
