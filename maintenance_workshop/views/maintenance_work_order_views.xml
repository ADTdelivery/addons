<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_maintenance_work_order_tree" model="ir.ui.view">
        <field name="name">maintenance.work.order.tree</field>
        <field name="model">maintenance.work.order</field>
        <field name="arch" type="xml">
            <tree string="Órdenes de Trabajo">
                <field name="name"/>
                <field name="client_id"/>
                <field name="mechanic_id"/>
                <field name="mileage"/>
                <field name="total_amount"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-info="state == 'in_progress'"
                       decoration-danger="state == 'blocked'"
                       decoration-success="state == 'done'"/>
                <field name="days_in_taller"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_maintenance_work_order_kanban" model="ir.ui.view">
        <field name="name">maintenance.work.order.kanban</field>
        <field name="model">maintenance.work.order</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_primary_bottom">
                                <div>
                                    <strong><field name="client_id"/></strong>
                                </div>
                                <div><field name="entry_reason"/></div>
                                <div><span class="o_badge o_badge_xs"><field name="total_amount"/></span></div>
                                <div><field name="state" widget="badge"/></div>
                                <div><field name="days_in_taller"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_maintenance_work_order_form" model="ir.ui.view">
        <field name="name">maintenance.work.order.form</field>
        <field name="model">maintenance.work.order</field>
        <field name="arch" type="xml">
            <form string="Orden de Trabajo">
                <header>
                    <button name="action_start" type="object" string="Iniciar" class="oe_highlight" attrs="{'invisible':[('state','!=','pending')]}"/>
                    <button name="action_block" type="object" string="Bloquear" class="btn-warning" attrs="{'invisible':[('state','!=','in_progress')]}"/>
                    <button name="action_unblock" type="object" string="Reanudar" class="btn-info" attrs="{'invisible':[('state','!=','blocked')]}"/>
                    <button name="action_done" type="object" string="Finalizar" class="btn-success" attrs="{'invisible':[('state','!=','in_progress')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,blocked,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="client_id"/>
                            <field name="mechanic_id"/>
                            <field name="mileage"/>
                            <field name="start_date"/>
                        </group>

                        <group>
                            <field name="total_amount" readonly="1" class="o_field_number o_field_money"/>
                            <field name="parts_total" readonly="1"/>
                            <field name="labor_total" readonly="1"/>
                            <field name="service_duration_hours" readonly="1"/>
                            <field name="days_in_taller" readonly="1"/>

                        </group>
                    </group>

                    <notebook>
                        <page string="General">
                            <group>
                                <field name="entry_reason"/>
                                <field name="evidence_image" widget="image"/>
                            </group>
                        </page>
                        <page string="Diagnóstico">
                            <group>
                                <field name="diagnostic"/>
                            </group>
                        </page>
                        <page string="Repuestos">
                            <field name="part_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal"/>
                                    <field name="notes"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                        <field name="subtotal" readonly="1"/>
                                        <field name="notes"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Mano de obra">
                            <field name="service_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="subtotal"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="description"/>
                                        <field name="subtotal"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Resultado y cierre">
                            <group>
                                <field name="final_state"/>
                                <field name="final_notes"/>
                                <field name="key_delivery_photo" widget="image"/>
                                <field name="next_revision_date"/>
                                <field name="mechanic_signature"/>
                                <field name="client_signature"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_maintenance_work_order" model="ir.actions.act_window">
        <field name="name">Órdenes Taller</field>
        <field name="res_model">maintenance.work.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[]</field>
    </record>

    <record id="view_maintenance_work_order_search" model="ir.ui.view">
        <field name="name">maintenance.work.order.search</field>
        <field name="model">maintenance.work.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <field name="mechanic_id"/>
                <filter name="filter_pending" string="Pendientes" domain="[('state','=','pending')]"/>
                <filter name="filter_in_progress" string="En progreso" domain="[('state','=','in_progress')]"/>
                <filter name="filter_blocked" string="Bloqueados" domain="[('state','=','blocked')]"/>
            </search>
        </field>
    </record>

</odoo>
